      <item ident="W05_Q08" title="Q08 — mean vs median">
        <itemmetadata><qtimetadata>
          <qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>multiple_choice_question</fieldentry></qtimetadatafield>
          <qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield>
        </qtimetadata></itemmetadata>
        <presentation><material><mattext texttype="text/html">&lt;p&gt;If df["revenue"].mean() = 1200 and df["revenue"].median() = 650, what does this suggest?&lt;/p&gt;</mattext></material>
          <response_lid ident="W05_Q08_RL" rcardinality="Single"><render_choice>
            <response_label ident="a"><material><mattext texttype="text/plain">Data is symmetric</mattext></material></response_label>
<response_label ident="b"><material><mattext texttype="text/plain">Data is left-skewed</mattext></material></response_label>
<response_label ident="c"><material><mattext texttype="text/plain">Data is right-skewed — large transactions pull the mean up</mattext></material></response_label>
<response_label ident="d"><material><mattext texttype="text/plain">There is an error</mattext></material></response_label>
          </render_choice></response_lid>
        </presentation>
        <resprocessing><outcomes><decvar maxvalue="1" minvalue="0" varname="SCORE" vartype="Decimal"/></outcomes>
          <respcondition continue="No"><conditionvar><varequal respident="W05_Q08_RL">C</varequal></conditionvar>
            <setvar action="Set" varname="SCORE">1</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="W05_Q08_FB_C"/>
          </respcondition>
          <respcondition continue="No"><conditionvar><other/></conditionvar>
            <setvar action="Set" varname="SCORE">0</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="W05_Q08_FB_W"/>
          </respcondition>
        </resprocessing>
        <itemfeedback ident="W05_Q08_FB_C"><material><mattext texttype="text/html">✓ Correct! Mean > median = right-skewed. A few very large transactions pull the mean upward. Median ($650) is more representative of a typical transaction.</mattext></material></itemfeedback>
        <itemfeedback ident="W05_Q08_FB_W"><material><mattext texttype="text/html">✗ Incorrect. Mean > median = right-skewed. A few very large transactions pull the mean upward. Median ($650) is more representative of a typical transaction.</mattext></material></itemfeedback>
      </item>
      <item ident="W05_Q09" title="Q09 — savefig">
        <itemmetadata><qtimetadata>
          <qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>multiple_choice_question</fieldentry></qtimetadatafield>
          <qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield>
        </qtimetadata></itemmetadata>
        <presentation><material><mattext texttype="text/html">&lt;p&gt;Why use index=False in df.to_csv("file.csv", index=False)?&lt;/p&gt;</mattext></material>
          <response_lid ident="W05_Q09_RL" rcardinality="Single"><render_choice>
            <response_label ident="a"><material><mattext texttype="text/plain">Makes the file smaller</mattext></material></response_label>
<response_label ident="b"><material><mattext texttype="text/plain">Prevents writing the row index (0,1,2...) as an extra column</mattext></material></response_label>
<response_label ident="c"><material><mattext texttype="text/plain">Required — to_csv fails without it</mattext></material></response_label>
<response_label ident="d"><material><mattext texttype="text/plain">Skips rows with NaN</mattext></material></response_label>
          </render_choice></response_lid>
        </presentation>
        <resprocessing><outcomes><decvar maxvalue="1" minvalue="0" varname="SCORE" vartype="Decimal"/></outcomes>
          <respcondition continue="No"><conditionvar><varequal respident="W05_Q09_RL">B</varequal></conditionvar>
            <setvar action="Set" varname="SCORE">1</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="W05_Q09_FB_C"/>
          </respcondition>
          <respcondition continue="No"><conditionvar><other/></conditionvar>
            <setvar action="Set" varname="SCORE">0</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="W05_Q09_FB_W"/>
          </respcondition>
        </resprocessing>
        <itemfeedback ident="W05_Q09_FB_C"><material><mattext texttype="text/html">✓ Correct! Without index=False, pandas writes the row numbers as "Unnamed: 0" in the output file. Always use index=False.</mattext></material></itemfeedback>
        <itemfeedback ident="W05_Q09_FB_W"><material><mattext texttype="text/html">✗ Incorrect. Without index=False, pandas writes the row numbers as "Unnamed: 0" in the output file. Always use index=False.</mattext></material></itemfeedback>
      </item>
      <item ident="W05_Q10" title="Q10 — str.title cleaning">
        <itemmetadata><qtimetadata>
          <qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>multiple_choice_question</fieldentry></qtimetadatafield>
          <qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield>
        </qtimetadata></itemmetadata>
        <presentation><material><mattext texttype="text/html">&lt;p&gt;Why apply df["region"].str.title() before groupby("region")?&lt;/p&gt;</mattext></material>
          <response_lid ident="W05_Q10_RL" rcardinality="Single"><render_choice>
            <response_label ident="a"><material><mattext texttype="text/plain">groupby only works on title-case columns</mattext></material></response_label>
<response_label ident="b"><material><mattext texttype="text/plain">It makes output look nicer</mattext></material></response_label>
<response_label ident="c"><material><mattext texttype="text/plain">"north","North","NORTH" are treated as three separate groups without normalization</mattext></material></response_label>
<response_label ident="d"><material><mattext texttype="text/plain">It converts strings to numbers</mattext></material></response_label>
          </render_choice></response_lid>
        </presentation>
        <resprocessing><outcomes><decvar maxvalue="1" minvalue="0" varname="SCORE" vartype="Decimal"/></outcomes>
          <respcondition continue="No"><conditionvar><varequal respident="W05_Q10_RL">C</varequal></conditionvar>
            <setvar action="Set" varname="SCORE">1</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="W05_Q10_FB_C"/>
          </respcondition>
          <respcondition continue="No"><conditionvar><other/></conditionvar>
            <setvar action="Set" varname="SCORE">0</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="W05_Q10_FB_W"/>
          </respcondition>
        </resprocessing>
        <itemfeedback ident="W05_Q10_FB_C"><material><mattext texttype="text/html">✓ Correct! pandas groupby is case-sensitive. Normalizing with .str.title() ensures all regions merge into one group per region. This is one of the most common real-world data bugs.</mattext></material></itemfeedback>
        <itemfeedback ident="W05_Q10_FB_W"><material><mattext texttype="text/html">✗ Incorrect. pandas groupby is case-sensitive. Normalizing with .str.title() ensures all regions merge into one group per region. This is one of the most common real-world data bugs.</mattext></material></itemfeedback>
      </item>
