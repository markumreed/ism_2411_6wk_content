      <item ident="W04_Q09" title="Q09 — sort_values">
        <itemmetadata><qtimetadata>
          <qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>multiple_choice_question</fieldentry></qtimetadatafield>
          <qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield>
        </qtimetadata></itemmetadata>
        <presentation><material><mattext texttype="text/html">&lt;p&gt;What is the key difference between df.sort_values("price") and list.sort()?&lt;/p&gt;</mattext></material>
          <response_lid ident="W04_Q09_RL" rcardinality="Single"><render_choice>
            <response_label ident="a"><material><mattext texttype="text/plain">sort_values() sorts alphabetically</mattext></material></response_label>
<response_label ident="b"><material><mattext texttype="text/plain">They are identical</mattext></material></response_label>
<response_label ident="c"><material><mattext texttype="text/plain">sort_values() returns a new df; list.sort() modifies in place</mattext></material></response_label>
<response_label ident="d"><material><mattext texttype="text/plain">sort_values() only works on numbers</mattext></material></response_label>
          </render_choice></response_lid>
        </presentation>
        <resprocessing><outcomes><decvar maxvalue="1" minvalue="0" varname="SCORE" vartype="Decimal"/></outcomes>
          <respcondition continue="No"><conditionvar><varequal respident="W04_Q09_RL">C</varequal></conditionvar>
            <setvar action="Set" varname="SCORE">1</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="W04_Q09_FB_C"/>
          </respcondition>
          <respcondition continue="No"><conditionvar><other/></conditionvar>
            <setvar action="Set" varname="SCORE">0</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="W04_Q09_FB_W"/>
          </respcondition>
        </resprocessing>
        <itemfeedback ident="W04_Q09_FB_C"><material><mattext texttype="text/html">✓ Correct! sort_values() returns a new DataFrame — must assign to save. list.sort() modifies the list in place and returns None.</mattext></material></itemfeedback>
        <itemfeedback ident="W04_Q09_FB_W"><material><mattext texttype="text/html">✗ Incorrect. sort_values() returns a new DataFrame — must assign to save. list.sort() modifies the list in place and returns None.</mattext></material></itemfeedback>
      </item>
      <item ident="W04_Q10" title="Q10 — dropna">
        <itemmetadata><qtimetadata>
          <qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>multiple_choice_question</fieldentry></qtimetadatafield>
          <qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield>
        </qtimetadata></itemmetadata>
        <presentation><material><mattext texttype="text/html">&lt;p&gt;What does df = df.dropna() do?&lt;/p&gt;</mattext></material>
          <response_lid ident="W04_Q10_RL" rcardinality="Single"><render_choice>
            <response_label ident="a"><material><mattext texttype="text/plain">Fills NaN with zero</mattext></material></response_label>
<response_label ident="b"><material><mattext texttype="text/plain">Modifies df in place without assignment</mattext></material></response_label>
<response_label ident="c"><material><mattext texttype="text/plain">Returns a new df with NaN rows removed, assigned back</mattext></material></response_label>
<response_label ident="d"><material><mattext texttype="text/plain">Removes columns with NaN</mattext></material></response_label>
          </render_choice></response_lid>
        </presentation>
        <resprocessing><outcomes><decvar maxvalue="1" minvalue="0" varname="SCORE" vartype="Decimal"/></outcomes>
          <respcondition continue="No"><conditionvar><varequal respident="W04_Q10_RL">C</varequal></conditionvar>
            <setvar action="Set" varname="SCORE">1</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="W04_Q10_FB_C"/>
          </respcondition>
          <respcondition continue="No"><conditionvar><other/></conditionvar>
            <setvar action="Set" varname="SCORE">0</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="W04_Q10_FB_W"/>
          </respcondition>
        </resprocessing>
        <itemfeedback ident="W04_Q10_FB_C"><material><mattext texttype="text/html">✓ Correct! dropna() returns a new DataFrame. Removes ROWS (not columns) with NaN. The assignment df = df.dropna() saves the result.</mattext></material></itemfeedback>
        <itemfeedback ident="W04_Q10_FB_W"><material><mattext texttype="text/html">✗ Incorrect. dropna() returns a new DataFrame. Removes ROWS (not columns) with NaN. The assignment df = df.dropna() saves the result.</mattext></material></itemfeedback>
      </item>
