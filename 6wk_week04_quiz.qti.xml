      <item ident="W04_Q01" title="Q01 — df mean">
        <itemmetadata><qtimetadata>
          <qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>multiple_choice_question</fieldentry></qtimetadatafield>
          <qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield>
        </qtimetadata></itemmetadata>
        <presentation><material><mattext texttype="text/html">&lt;p&gt;import pandas as pd&lt;br&gt;df = pd.DataFrame({"item":["pen","book"],"price":[1.5,12.0]})&lt;br&gt;print(df["price"].mean())&lt;/p&gt;</mattext></material>
          <response_lid ident="W04_Q01_RL" rcardinality="Single"><render_choice>
            <response_label ident="a"><material><mattext texttype="text/plain">13.5</mattext></material></response_label>
<response_label ident="b"><material><mattext texttype="text/plain">1.5</mattext></material></response_label>
<response_label ident="c"><material><mattext texttype="text/plain">6.75</mattext></material></response_label>
<response_label ident="d"><material><mattext texttype="text/plain">12.0</mattext></material></response_label>
          </render_choice></response_lid>
        </presentation>
        <resprocessing><outcomes><decvar maxvalue="1" minvalue="0" varname="SCORE" vartype="Decimal"/></outcomes>
          <respcondition continue="No"><conditionvar><varequal respident="W04_Q01_RL">C</varequal></conditionvar>
            <setvar action="Set" varname="SCORE">1</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="W04_Q01_FB_C"/>
          </respcondition>
          <respcondition continue="No"><conditionvar><other/></conditionvar>
            <setvar action="Set" varname="SCORE">0</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="W04_Q01_FB_W"/>
          </respcondition>
        </resprocessing>
        <itemfeedback ident="W04_Q01_FB_C"><material><mattext texttype="text/html">✓ Correct! (1.5 + 12.0) / 2 = 13.5 / 2 = 6.75. Verbatim Q1.</mattext></material></itemfeedback>
        <itemfeedback ident="W04_Q01_FB_W"><material><mattext texttype="text/html">✗ Incorrect. (1.5 + 12.0) / 2 = 13.5 / 2 = 6.75. Verbatim Q1.</mattext></material></itemfeedback>
      </item>
