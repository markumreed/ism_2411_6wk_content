        <itemfeedback ident="W01_Q05_FB_C"><material><mattext texttype="text/html">✓ Correct! % returns the remainder. 17 = 3×5 + 2. Remainder = 2. Verbatim Q5.</mattext></material></itemfeedback>
        <itemfeedback ident="W01_Q05_FB_W"><material><mattext texttype="text/html">✗ Incorrect. % returns the remainder. 17 = 3×5 + 2. Remainder = 2. Verbatim Q5.</mattext></material></itemfeedback>
      </item>
