      <item ident="W01_Q08" title="Q08 — reassignment">
        <itemmetadata><qtimetadata>
          <qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>multiple_choice_question</fieldentry></qtimetadatafield>
          <qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield>
        </qtimetadata></itemmetadata>
        <presentation><material><mattext texttype="text/html">&lt;p&gt;x = 5  x = x + 3  print(x)&lt;/p&gt;</mattext></material>
          <response_lid ident="W01_Q08_RL" rcardinality="Single"><render_choice>
            <response_label ident="a"><material><mattext texttype="text/plain">5</mattext></material></response_label>
<response_label ident="b"><material><mattext texttype="text/plain">3</mattext></material></response_label>
<response_label ident="c"><material><mattext texttype="text/plain">8</mattext></material></response_label>
<response_label ident="d"><material><mattext texttype="text/plain">Error</mattext></material></response_label>
          </render_choice></response_lid>
        </presentation>
        <resprocessing><outcomes><decvar maxvalue="1" minvalue="0" varname="SCORE" vartype="Decimal"/></outcomes>
          <respcondition continue="No"><conditionvar><varequal respident="W01_Q08_RL">C</varequal></conditionvar>
            <setvar action="Set" varname="SCORE">1</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="W01_Q08_FB_C"/>
          </respcondition>
          <respcondition continue="No"><conditionvar><other/></conditionvar>
            <setvar action="Set" varname="SCORE">0</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="W01_Q08_FB_W"/>
          </respcondition>
        </resprocessing>
        <itemfeedback ident="W01_Q08_FB_C"><material><mattext texttype="text/html">✓ Correct! x starts at 5. x = x + 3 evaluates the right side first: 5 + 3 = 8. Then assigns 8 back to x. Output: 8.</mattext></material></itemfeedback>
        <itemfeedback ident="W01_Q08_FB_W"><material><mattext texttype="text/html">✗ Incorrect. x starts at 5. x = x + 3 evaluates the right side first: 5 + 3 = 8. Then assigns 8 back to x. Output: 8.</mattext></material></itemfeedback>
      </item>
      <item ident="W01_Q09" title="Q09 — int vs float">
        <itemmetadata><qtimetadata>
          <qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>multiple_choice_question</fieldentry></qtimetadatafield>
          <qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield>
        </qtimetadata></itemmetadata>
        <presentation><material><mattext texttype="text/html">&lt;p&gt;What type does Python assign to the value 42?&lt;/p&gt;</mattext></material>
          <response_lid ident="W01_Q09_RL" rcardinality="Single"><render_choice>
            <response_label ident="a"><material><mattext texttype="text/plain">str</mattext></material></response_label>
<response_label ident="b"><material><mattext texttype="text/plain">float</mattext></material></response_label>
<response_label ident="c"><material><mattext texttype="text/plain">int</mattext></material></response_label>
<response_label ident="d"><material><mattext texttype="text/plain">bool</mattext></material></response_label>
          </render_choice></response_lid>
        </presentation>
        <resprocessing><outcomes><decvar maxvalue="1" minvalue="0" varname="SCORE" vartype="Decimal"/></outcomes>
          <respcondition continue="No"><conditionvar><varequal respident="W01_Q09_RL">C</varequal></conditionvar>
            <setvar action="Set" varname="SCORE">1</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="W01_Q09_FB_C"/>
          </respcondition>
          <respcondition continue="No"><conditionvar><other/></conditionvar>
            <setvar action="Set" varname="SCORE">0</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="W01_Q09_FB_W"/>
          </respcondition>
        </resprocessing>
        <itemfeedback ident="W01_Q09_FB_C"><material><mattext texttype="text/html">✓ Correct! 42 has no decimal point so Python infers int. 42.0 would be float.</mattext></material></itemfeedback>
        <itemfeedback ident="W01_Q09_FB_W"><material><mattext texttype="text/html">✗ Incorrect. 42 has no decimal point so Python infers int. 42.0 would be float.</mattext></material></itemfeedback>
      </item>
      <item ident="W01_Q10" title="Q10 — type conversion">
        <itemmetadata><qtimetadata>
          <qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>multiple_choice_question</fieldentry></qtimetadatafield>
          <qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield>
        </qtimetadata></itemmetadata>
        <presentation><material><mattext texttype="text/html">&lt;p&gt;price_str = "49.99"  revenue = float(price_str) * 3  print(revenue)&lt;/p&gt;</mattext></material>
          <response_lid ident="W01_Q10_RL" rcardinality="Single"><render_choice>
            <response_label ident="a"><material><mattext texttype="text/plain">TypeError</mattext></material></response_label>
<response_label ident="b"><material><mattext texttype="text/plain">149.97</mattext></material></response_label>
<response_label ident="c"><material><mattext texttype="text/plain">"49.99" * 3</mattext></material></response_label>
<response_label ident="d"><material><mattext texttype="text/plain">Error</mattext></material></response_label>
          </render_choice></response_lid>
        </presentation>
        <resprocessing><outcomes><decvar maxvalue="1" minvalue="0" varname="SCORE" vartype="Decimal"/></outcomes>
          <respcondition continue="No"><conditionvar><varequal respident="W01_Q10_RL">B</varequal></conditionvar>
            <setvar action="Set" varname="SCORE">1</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="W01_Q10_FB_C"/>
          </respcondition>
          <respcondition continue="No"><conditionvar><other/></conditionvar>
            <setvar action="Set" varname="SCORE">0</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="W01_Q10_FB_W"/>
          </respcondition>
        </resprocessing>
        <itemfeedback ident="W01_Q10_FB_C"><material><mattext texttype="text/html">✓ Correct! float("49.99") converts the string to 49.99. 49.99 * 3 = 149.97. Without float(), multiplying a string by an int repeats it — which would raise a TypeError for non-integer multiplication.</mattext></material></itemfeedback>
        <itemfeedback ident="W01_Q10_FB_W"><material><mattext texttype="text/html">✗ Incorrect. float("49.99") converts the string to 49.99. 49.99 * 3 = 149.97. Without float(), multiplying a string by an int repeats it — which would raise a TypeError for non-integer multiplication.</mattext></material></itemfeedback>
      </item>
