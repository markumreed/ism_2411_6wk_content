      <item ident="W03_Q04" title="Q04 — tuple immutability">
        <itemmetadata><qtimetadata>
          <qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>multiple_choice_question</fieldentry></qtimetadatafield>
          <qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield>
        </qtimetadata></itemmetadata>
        <presentation><material><mattext texttype="text/html">&lt;p&gt;What is the key difference between a list and a tuple?&lt;/p&gt;</mattext></material>
          <response_lid ident="W03_Q04_RL" rcardinality="Single"><render_choice>
            <response_label ident="a"><material><mattext texttype="text/plain">Tuples hold more items</mattext></material></response_label>
<response_label ident="b"><material><mattext texttype="text/plain">Lists use {}; tuples use []</mattext></material></response_label>
<response_label ident="c"><material><mattext texttype="text/plain">Tuples are immutable; lists are mutable</mattext></material></response_label>
<response_label ident="d"><material><mattext texttype="text/plain">Lists hold only strings</mattext></material></response_label>
          </render_choice></response_lid>
        </presentation>
        <resprocessing><outcomes><decvar maxvalue="1" minvalue="0" varname="SCORE" vartype="Decimal"/></outcomes>
          <respcondition continue="No"><conditionvar><varequal respident="W03_Q04_RL">C</varequal></conditionvar>
            <setvar action="Set" varname="SCORE">1</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="W03_Q04_FB_C"/>
          </respcondition>
          <respcondition continue="No"><conditionvar><other/></conditionvar>
            <setvar action="Set" varname="SCORE">0</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="W03_Q04_FB_W"/>
          </respcondition>
        </resprocessing>
        <itemfeedback ident="W03_Q04_FB_C"><material><mattext texttype="text/html">✓ Correct! Tuples are immutable — once created, they cannot be modified. Lists are mutable — you can add, remove, or change items. Verbatim Q4.</mattext></material></itemfeedback>
        <itemfeedback ident="W03_Q04_FB_W"><material><mattext texttype="text/html">✗ Incorrect. Tuples are immutable — once created, they cannot be modified. Lists are mutable — you can add, remove, or change items. Verbatim Q4.</mattext></material></itemfeedback>
      </item>
      <item ident="W03_Q05" title="Q05 — relative paths">
        <itemmetadata><qtimetadata>
          <qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>multiple_choice_question</fieldentry></qtimetadatafield>
          <qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield>
        </qtimetadata></itemmetadata>
        <presentation><material><mattext texttype="text/html">&lt;p&gt;Why use relative file paths (data/sales.csv) instead of absolute paths (/Users/john/Desktop/data/sales.csv)?&lt;/p&gt;</mattext></material>
          <response_lid ident="W03_Q05_RL" rcardinality="Single"><render_choice>
            <response_label ident="a"><material><mattext texttype="text/plain">Shorter to type</mattext></material></response_label>
<response_label ident="b"><material><mattext texttype="text/plain">Work on any machine regardless of where the project is stored</mattext></material></response_label>
<response_label ident="c"><material><mattext texttype="text/plain">Run faster</mattext></material></response_label>
<response_label ident="d"><material><mattext texttype="text/plain">Required by the csv module</mattext></material></response_label>
          </render_choice></response_lid>
        </presentation>
        <resprocessing><outcomes><decvar maxvalue="1" minvalue="0" varname="SCORE" vartype="Decimal"/></outcomes>
          <respcondition continue="No"><conditionvar><varequal respident="W03_Q05_RL">B</varequal></conditionvar>
            <setvar action="Set" varname="SCORE">1</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="W03_Q05_FB_C"/>
          </respcondition>
          <respcondition continue="No"><conditionvar><other/></conditionvar>
            <setvar action="Set" varname="SCORE">0</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="W03_Q05_FB_W"/>
          </respcondition>
        </resprocessing>
        <itemfeedback ident="W03_Q05_FB_C"><material><mattext texttype="text/html">✓ Correct! Relative paths work on any machine. Absolute paths break when the project moves to a different computer or when another person clones the repo. Verbatim Q5.</mattext></material></itemfeedback>
        <itemfeedback ident="W03_Q05_FB_W"><material><mattext texttype="text/html">✗ Incorrect. Relative paths work on any machine. Absolute paths break when the project moves to a different computer or when another person clones the repo. Verbatim Q5.</mattext></material></itemfeedback>
      </item>
      <item ident="W03_Q06" title="Q06 — dict .get()">
        <itemmetadata><qtimetadata>
          <qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>multiple_choice_question</fieldentry></qtimetadatafield>
          <qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield>
        </qtimetadata></itemmetadata>
        <presentation><material><mattext texttype="text/html">&lt;p&gt;customer = {"name": "Alice", "age": 30}&lt;br&gt;print(customer.get("email", "Not found"))&lt;/p&gt;</mattext></material>
          <response_lid ident="W03_Q06_RL" rcardinality="Single"><render_choice>
            <response_label ident="a"><material><mattext texttype="text/plain">None</mattext></material></response_label>
<response_label ident="b"><material><mattext texttype="text/plain">Error</mattext></material></response_label>
<response_label ident="c"><material><mattext texttype="text/plain">"Not found"</mattext></material></response_label>
<response_label ident="d"><material><mattext texttype="text/plain">"email"</mattext></material></response_label>
          </render_choice></response_lid>
        </presentation>
        <resprocessing><outcomes><decvar maxvalue="1" minvalue="0" varname="SCORE" vartype="Decimal"/></outcomes>
          <respcondition continue="No"><conditionvar><varequal respident="W03_Q06_RL">C</varequal></conditionvar>
            <setvar action="Set" varname="SCORE">1</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="W03_Q06_FB_C"/>
          </respcondition>
          <respcondition continue="No"><conditionvar><other/></conditionvar>
            <setvar action="Set" varname="SCORE">0</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="W03_Q06_FB_W"/>
          </respcondition>
        </resprocessing>
        <itemfeedback ident="W03_Q06_FB_C"><material><mattext texttype="text/html">✓ Correct! .get(key, default) returns the value if the key exists, or the default if it does not. "email" is not in the dict → returns "Not found". Verbatim Q6.</mattext></material></itemfeedback>
        <itemfeedback ident="W03_Q06_FB_W"><material><mattext texttype="text/html">✗ Incorrect. .get(key, default) returns the value if the key exists, or the default if it does not. "email" is not in the dict → returns "Not found". Verbatim Q6.</mattext></material></itemfeedback>
      </item>
      <item ident="W03_Q07" title="Q07 — dict iteration">
        <itemmetadata><qtimetadata>
          <qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>multiple_choice_question</fieldentry></qtimetadatafield>
          <qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield>
        </qtimetadata></itemmetadata>
        <presentation><material><mattext texttype="text/html">&lt;p&gt;inventory = {"apples": 10, "bananas": 5}&lt;br&gt;for item in inventory:&lt;br&gt;    print(item)&lt;/p&gt;</mattext></material>
          <response_lid ident="W03_Q07_RL" rcardinality="Single"><render_choice>
            <response_label ident="a"><material><mattext texttype="text/plain">10 5</mattext></material></response_label>
<response_label ident="b"><material><mattext texttype="text/plain">apples bananas</mattext></material></response_label>
<response_label ident="c"><material><mattext texttype="text/plain">{"apples":10}</mattext></material></response_label>
<response_label ident="d"><material><mattext texttype="text/plain">Error</mattext></material></response_label>
          </render_choice></response_lid>
        </presentation>
        <resprocessing><outcomes><decvar maxvalue="1" minvalue="0" varname="SCORE" vartype="Decimal"/></outcomes>
          <respcondition continue="No"><conditionvar><varequal respident="W03_Q07_RL">B</varequal></conditionvar>
            <setvar action="Set" varname="SCORE">1</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="W03_Q07_FB_C"/>
          </respcondition>
          <respcondition continue="No"><conditionvar><other/></conditionvar>
            <setvar action="Set" varname="SCORE">0</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="W03_Q07_FB_W"/>
          </respcondition>
        </resprocessing>
        <itemfeedback ident="W03_Q07_FB_C"><material><mattext texttype="text/html">✓ Correct! Iterating a dict returns its KEYS, not values. To get values: for v in inventory.values(). To get both: for k,v in inventory.items(). Verbatim Q7.</mattext></material></itemfeedback>
        <itemfeedback ident="W03_Q07_FB_W"><material><mattext texttype="text/html">✗ Incorrect. Iterating a dict returns its KEYS, not values. To get values: for v in inventory.values(). To get both: for k,v in inventory.items(). Verbatim Q7.</mattext></material></itemfeedback>
      </item>
