        <itemfeedback ident="W03_Q08_FB_W"><material><mattext texttype="text/html">✗ Incorrect. The tuple has 2 elements: 40.7128 and -74.0060. len() returns 2. Verbatim Q8.</mattext></material></itemfeedback>
      </item>
      <item ident="W03_Q09" title="Q09 — dict method">
        <itemmetadata><qtimetadata>
          <qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>multiple_choice_question</fieldentry></qtimetadatafield>
          <qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield>
        </qtimetadata></itemmetadata>
        <presentation><material><mattext texttype="text/html">&lt;p&gt;Which dict method returns all key-value pairs as tuples?&lt;/p&gt;</mattext></material>
          <response_lid ident="W03_Q09_RL" rcardinality="Single"><render_choice>
            <response_label ident="a"><material><mattext texttype="text/plain">.keys()</mattext></material></response_label>
<response_label ident="b"><material><mattext texttype="text/plain">.values()</mattext></material></response_label>
<response_label ident="c"><material><mattext texttype="text/plain">.items()</mattext></material></response_label>
<response_label ident="d"><material><mattext texttype="text/plain">.pairs()</mattext></material></response_label>
          </render_choice></response_lid>
        </presentation>
        <resprocessing><outcomes><decvar maxvalue="1" minvalue="0" varname="SCORE" vartype="Decimal"/></outcomes>
          <respcondition continue="No"><conditionvar><varequal respident="W03_Q09_RL">C</varequal></conditionvar>
            <setvar action="Set" varname="SCORE">1</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="W03_Q09_FB_C"/>
          </respcondition>
          <respcondition continue="No"><conditionvar><other/></conditionvar>
            <setvar action="Set" varname="SCORE">0</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="W03_Q09_FB_W"/>
          </respcondition>
        </resprocessing>
        <itemfeedback ident="W03_Q09_FB_C"><material><mattext texttype="text/html">✓ Correct! .items() returns a view of (key, value) tuples — used in for k,v in d.items() loops. .pairs() does not exist. Verbatim Q9.</mattext></material></itemfeedback>
        <itemfeedback ident="W03_Q09_FB_W"><material><mattext texttype="text/html">✗ Incorrect. .items() returns a view of (key, value) tuples — used in for k,v in d.items() loops. .pairs() does not exist. Verbatim Q9.</mattext></material></itemfeedback>
      </item>
      <item ident="W03_Q10" title="Q10 — csv DictReader">
        <itemmetadata><qtimetadata>
          <qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>multiple_choice_question</fieldentry></qtimetadatafield>
          <qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield>
        </qtimetadata></itemmetadata>
        <presentation><material><mattext texttype="text/html">&lt;p&gt;When using csv.DictReader to read a CSV, what type is each row?&lt;/p&gt;</mattext></material>
          <response_lid ident="W03_Q10_RL" rcardinality="Single"><render_choice>
            <response_label ident="a"><material><mattext texttype="text/plain">A list</mattext></material></response_label>
<response_label ident="b"><material><mattext texttype="text/plain">A tuple</mattext></material></response_label>
<response_label ident="c"><material><mattext texttype="text/plain">A dict</mattext></material></response_label>
<response_label ident="d"><material><mattext texttype="text/plain">A string</mattext></material></response_label>
          </render_choice></response_lid>
        </presentation>
        <resprocessing><outcomes><decvar maxvalue="1" minvalue="0" varname="SCORE" vartype="Decimal"/></outcomes>
          <respcondition continue="No"><conditionvar><varequal respident="W03_Q10_RL">C</varequal></conditionvar>
            <setvar action="Set" varname="SCORE">1</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="W03_Q10_FB_C"/>
          </respcondition>
          <respcondition continue="No"><conditionvar><other/></conditionvar>
            <setvar action="Set" varname="SCORE">0</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="W03_Q10_FB_W"/>
          </respcondition>
        </resprocessing>
        <itemfeedback ident="W03_Q10_FB_C"><material><mattext texttype="text/html">✓ Correct! DictReader reads each row as a dict where keys are the header column names. This is why you write row["price"] instead of row[2].</mattext></material></itemfeedback>
        <itemfeedback ident="W03_Q10_FB_W"><material><mattext texttype="text/html">✗ Incorrect. DictReader reads each row as a dict where keys are the header column names. This is why you write row["price"] instead of row[2].</mattext></material></itemfeedback>
      </item>
    </section>
