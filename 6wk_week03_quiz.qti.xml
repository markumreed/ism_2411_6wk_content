      <item ident="W03_Q01" title="Q01 — list operations">
        <itemmetadata><qtimetadata>
          <qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>multiple_choice_question</fieldentry></qtimetadatafield>
          <qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield>
        </qtimetadata></itemmetadata>
        <presentation><material><mattext texttype="text/html">&lt;p&gt;inventory = ["apples","bananas"]&lt;br&gt;inventory.append("oranges")&lt;br&gt;inventory.remove("bananas")&lt;br&gt;print(inventory)&lt;/p&gt;</mattext></material>
          <response_lid ident="W03_Q01_RL" rcardinality="Single"><render_choice>
            <response_label ident="a"><material><mattext texttype="text/plain">["apples","bananas","oranges"]</mattext></material></response_label>
<response_label ident="b"><material><mattext texttype="text/plain">["apples","oranges"]</mattext></material></response_label>
<response_label ident="c"><material><mattext texttype="text/plain">["bananas","oranges"]</mattext></material></response_label>
<response_label ident="d"><material><mattext texttype="text/plain">Error</mattext></material></response_label>
          </render_choice></response_lid>
        </presentation>
        <resprocessing><outcomes><decvar maxvalue="1" minvalue="0" varname="SCORE" vartype="Decimal"/></outcomes>
          <respcondition continue="No"><conditionvar><varequal respident="W03_Q01_RL">B</varequal></conditionvar>
            <setvar action="Set" varname="SCORE">1</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="W03_Q01_FB_C"/>
          </respcondition>
          <respcondition continue="No"><conditionvar><other/></conditionvar>
            <setvar action="Set" varname="SCORE">0</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="W03_Q01_FB_W"/>
          </respcondition>
        </resprocessing>
        <itemfeedback ident="W03_Q01_FB_C"><material><mattext texttype="text/html">✓ Correct! Start: ["apples","bananas"]. append("oranges") → ["apples","bananas","oranges"]. remove("bananas") → ["apples","oranges"]. Verbatim Q1.</mattext></material></itemfeedback>
        <itemfeedback ident="W03_Q01_FB_W"><material><mattext texttype="text/html">✗ Incorrect. Start: ["apples","bananas"]. append("oranges") → ["apples","bananas","oranges"]. remove("bananas") → ["apples","oranges"]. Verbatim Q1.</mattext></material></itemfeedback>
      </item>
