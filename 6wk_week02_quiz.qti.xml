<response_label ident="b"><material><mattext texttype="text/plain">10</mattext></material></response_label>
<response_label ident="c"><material><mattext texttype="text/plain">120</mattext></material></response_label>
<response_label ident="d"><material><mattext texttype="text/plain">Error</mattext></material></response_label>
          </render_choice></response_lid>
        </presentation>
        <resprocessing><outcomes><decvar maxvalue="1" minvalue="0" varname="SCORE" vartype="Decimal"/></outcomes>
          <respcondition continue="No"><conditionvar><varequal respident="W02_Q08_RL">B</varequal></conditionvar>
            <setvar action="Set" varname="SCORE">1</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="W02_Q08_FB_C"/>
          </respcondition>
          <respcondition continue="No"><conditionvar><other/></conditionvar>
            <setvar action="Set" varname="SCORE">0</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="W02_Q08_FB_W"/>
          </respcondition>
        </resprocessing>
        <itemfeedback ident="W02_Q08_FB_C"><material><mattext texttype="text/html">✓ Correct! 120 > 100 is True, so discount = 10 executes. Output: 10. Verbatim (Week 2 Q3).</mattext></material></itemfeedback>
        <itemfeedback ident="W02_Q08_FB_W"><material><mattext texttype="text/html">✗ Incorrect. 120 > 100 is True, so discount = 10 executes. Output: 10. Verbatim (Week 2 Q3).</mattext></material></itemfeedback>
      </item>
      <item ident="W02_Q09" title="Q09 — return vs print">
        <itemmetadata><qtimetadata>
          <qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>multiple_choice_question</fieldentry></qtimetadatafield>
          <qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield>
        </qtimetadata></itemmetadata>
        <presentation><material><mattext texttype="text/html">&lt;p&gt;What is the difference between print() and return inside a function?&lt;/p&gt;</mattext></material>
          <response_lid ident="W02_Q09_RL" rcardinality="Single"><render_choice>
            <response_label ident="a"><material><mattext texttype="text/plain">They are identical</mattext></material></response_label>
<response_label ident="b"><material><mattext texttype="text/plain">print() shows output; return sends a value back to the caller</mattext></material></response_label>
<response_label ident="c"><material><mattext texttype="text/plain">return shows output; print() sends a value back</mattext></material></response_label>
<response_label ident="d"><material><mattext texttype="text/plain">return only works inside loops</mattext></material></response_label>
          </render_choice></response_lid>
        </presentation>
        <resprocessing><outcomes><decvar maxvalue="1" minvalue="0" varname="SCORE" vartype="Decimal"/></outcomes>
          <respcondition continue="No"><conditionvar><varequal respident="W02_Q09_RL">B</varequal></conditionvar>
            <setvar action="Set" varname="SCORE">1</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="W02_Q09_FB_C"/>
          </respcondition>
          <respcondition continue="No"><conditionvar><other/></conditionvar>
            <setvar action="Set" varname="SCORE">0</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="W02_Q09_FB_W"/>
          </respcondition>
        </resprocessing>
        <itemfeedback ident="W02_Q09_FB_C"><material><mattext texttype="text/html">✓ Correct! print() displays to the screen but the value is not usable by the calling code. return sends the value back so it can be stored, used in calculations, or passed to other functions.</mattext></material></itemfeedback>
        <itemfeedback ident="W02_Q09_FB_W"><material><mattext texttype="text/html">✗ Incorrect. print() displays to the screen but the value is not usable by the calling code. return sends the value back so it can be stored, used in calculations, or passed to other functions.</mattext></material></itemfeedback>
      </item>
      <item ident="W02_Q10" title="Q10 — range">
